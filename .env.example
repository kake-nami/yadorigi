# ─────────────────────────────────────────────────────────────────────
# Yadorigi — Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL="file:./data/yadorigi.db"

# ── Yadorigi: DB暗号化 ───────────────────────────────────────────────
# 開発用：DB暗号化を無効化（本番・ホスト直接起動では設定しないこと）
# Docker環境では必須（OSキーチェーンが利用できないため）
# YADORIGI_NO_ENCRYPTION=1

# ── X OAuth（Live Import用・オプション） ──────────────────────────────
# X Developer Portal でアプリを作成して取得: https://developer.x.com
# X_OAUTH_CLIENT_ID=
# X_OAUTH_CLIENT_SECRET=

# アプリのベースURL（X OAuthのリダイレクトURIに使用）
# 本番環境では必須。未設定時は http://localhost:3000 にフォールバック
# YADORIGI_BASE_URL=https://your-domain.example.com

# ── Anthropic API（AI機能用・オプション） ────────────────────────────

# Option A: Claude CLI OAuth token（Claude サブスクリプション利用）
# ローカルでは自動でキーチェーンから読み込まれる（設定不要）
# ANTHROPIC_CLI_KEY=

# Option B: Anthropic API key（従量課金）
# https://console.anthropic.com で取得（sk-ant-api03- で始まる）
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional: APIのベースURL（プロキシ・ローカルモデルサーバー用）
# ANTHROPIC_BASE_URL=

# ── その他のAIプロバイダー（オプション） ──────────────────────────────
# MiniMax API key
# MINIMAX_API_KEY=eyJ...
# MINIMAX_BASE_URL=

# OpenAI API key
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=

# ── アクセス制御（オプション） ────────────────────────────────────────
# 両方設定するとアプリ全体にHTTP Basic認証が有効になる
# 外部URLで公開する場合（Cloudflare Tunnel等）に推奨
# SIFTLY_USERNAME=admin
# SIFTLY_PASSWORD=your-passphrase-here

# ── インポートオプション ───────────────────────────────────────────────
# インポート成功後にAI自動カテゴライズを実行する（オプトイン）
# AUTO_CATEGORIZE_AFTER_IMPORT=true
